{
	"$schema": "https://www.schemastore.org/package.json",
	"name": "backend",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "bun --hot src/main.ts",
		"build": "bun run src/build.ts",
		"start": "bun run dist/main.js",
		"db:mig": "bunx --bun prisma migrate dev --create-only",
		"db:push": "bunx --bun prisma migrate deploy",
		"db:gen": "bunx --bun prisma generate",
		"db:studio": "bunx --bun prisma studio",
		"db:seed": "bunx --bun prisma db seed",
		"db:reset": "bunx --bun prisma migrate reset",
		"api:gen": "corpus api"
	},
	"dependencies": {
		"@ozanarslan/corpus": "^0.5.10",
		"@prisma/adapter-libsql": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"arktype": "^2.2.0",
		"jsonwebtoken": "^9.0.3",
		"log4js": "^6.9.1",
		"nodemailer": "^8.0.7",
		"typescript": "^6.0.3"
	},
	"devDependencies": {
		"@ozanarslan/corpus-cli": "^0.5.10",
		"@types/bun": "^1.3.13",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/nodemailer": "^8.0.0",
		"prisma": "^7.8.0"
	},
	"trustedDependencies": [
		"@prisma/engines",
		"prisma"
	]
}
