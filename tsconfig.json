{
	"compilerOptions": {
		// Latest features
		"target": "ESNext",
		"module": "Preserve",
		"moduleDetection": "force",
		"moduleResolution": "bundler",
		"jsx": "react-jsx",
		"allowJs": true,
		"esModuleInterop": true,
		// Bundler mode
		"allowImportingTsExtensions": true,
		"verbatimModuleSyntax": true,
		"noEmit": true,
		// Strictness — applied everywhere
		"strict": true,
		"skipLibCheck": true,
		"noFallthroughCasesInSwitch": true,
		"noUncheckedIndexedAccess": true,
		"noImplicitOverride": true,
		// Stricter flags left off by default; packages can opt in
		"noUnusedLocals": true,
		"noUnusedParameters": true
	}
}
